@page "/submit"
@using Poll_it.Shared
@using Microsoft.AspNetCore.SignalR.Client
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Enviar Dolor - Poll-it</PageTitle>

<!-- 
    ARQUITECTURA - COMPONENTE DE ENTRADA
    =====================================
    
    Este componente es la interfaz de entrada donde los usuarios envían sus "dolores".
    
    RESPONSABILIDADES:
    1. Capturar el input del usuario
    2. Validar que no esté vacío
    3. Enviar al servidor via HTTP POST
    4. Proporcionar feedback visual
    
    SEPARACIÓN DE CONCERNS:
    - UI: Este componente solo maneja la presentación y captura de datos
    - Lógica: El servidor valida y persiste
    - Comunicación: SignalR maneja la notificación a otros clientes
    
    El componente NO necesita conocer SignalR porque:
    - El servidor se encarga de notificar a todos
    - Este componente solo envía y espera confirmación
    - Simplicidad: cada componente hace una cosa bien
-->

<div class="min-h-screen bg-gradient-to-br from-purple-50 to-blue-50 flex items-center justify-center p-4">
    <div class="max-w-2xl w-full bg-white rounded-2xl shadow-2xl p-8 md:p-12">
        <!-- Título Principal -->
        <div class="text-center mb-8">
            <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-3">
                📝 Poll-it
            </h1>
            <p class="text-xl text-gray-600">
                Comparte tu mayor dolor técnico
            </p>
        </div>

        <!-- Formulario -->
        <div class="space-y-6">
            <!-- Campo de Texto -->
            <div>
                <label for="painText" class="block text-lg font-medium text-gray-700 mb-2">
                    ¿Cuál es tu mayor dolor técnico hoy?
                </label>
                <textarea 
                    id="painText"
                    @bind="painText" 
                    @bind:event="oninput"
                    class="w-full px-4 py-3 text-lg border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent resize-none transition-all"
                    rows="4"
                    placeholder="Ejemplo: Los tests unitarios no paran de fallar..."
                    maxlength="200"
                    disabled="@isSubmitting">
                </textarea>
                <div class="flex justify-between items-center mt-2">
                    <span class="text-sm text-gray-500">
                        @painText.Length / 200 caracteres
                    </span>
                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <span class="text-sm text-red-600 font-medium">
                            @errorMessage
                        </span>
                    }
                </div>
            </div>

            <!-- Botón de Envío -->
            <button 
                @onclick="SubmitPainPoint"
                disabled="@(isSubmitting || string.IsNullOrWhiteSpace(painText))"
                class="w-full bg-gradient-to-r from-purple-600 to-blue-600 text-white text-lg font-semibold py-4 px-6 rounded-lg hover:from-purple-700 hover:to-blue-700 disabled:from-gray-300 disabled:to-gray-400 disabled:cursor-not-allowed transition-all transform hover:scale-105 active:scale-95 shadow-lg">
                @if (isSubmitting)
                {
                    <span class="flex items-center justify-center">
                        <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        Enviando...
                    </span>
                }
                else
                {
                    <span>🚀 Enviar mi Dolor</span>
                }
            </button>

            <!-- Mensaje de Éxito -->
            @if (showSuccessMessage)
            {
                <div class="bg-green-50 border-2 border-green-500 rounded-lg p-4 text-center animate-fade-in">
                    <p class="text-green-700 font-medium">
                        ✅ ¡Dolor enviado exitosamente! Todos lo verán en tiempo real.
                    </p>
                </div>
            }

            <!-- Link al Muro -->
            <div class="text-center pt-4">
                <a href="/wall" class="text-purple-600 hover:text-purple-800 font-medium text-lg underline">
                    👀 Ver el Muro de Dolores
                </a>
            </div>
        </div>

        <!-- Información Adicional -->
        <div class="mt-12 pt-8 border-t border-gray-200">
            <div class="text-center text-gray-600">
                <p class="text-sm">
                    💡 <strong>Tip:</strong> Sé específico pero conciso. Tu dolor aparecerá instantáneamente en el muro compartido.
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Texto del dolor ingresado por el usuario.
    /// </summary>
    private string painText = string.Empty;

    /// <summary>
    /// Indica si se está enviando el dolor al servidor.
    /// </summary>
    private bool isSubmitting = false;

    /// <summary>
    /// Muestra el mensaje de éxito después del envío.
    /// </summary>
    private bool showSuccessMessage = false;

    /// <summary>
    /// Mensaje de error para mostrar al usuario.
    /// </summary>
    private string errorMessage = string.Empty;

    /// <summary>
    /// Envía el punto de dolor al servidor via HTTP POST.
    /// </summary>
    /// <remarks>
    /// FLUJO DE LA OPERACIÓN:
    /// 1. Valida que el texto no esté vacío
    /// 2. Muestra indicador de carga
    /// 3. Envía POST al endpoint /api/painpoints
    /// 4. El SERVIDOR se encarga de:
    ///    - Guardar en BD
    ///    - Notificar a todos via SignalR
    /// 5. Muestra mensaje de éxito
    /// 6. Limpia el formulario
    /// 
    /// ARQUITECTURA:
    /// - Este componente NO maneja SignalR directamente
    /// - El servidor centraliza la lógica de broadcast
    /// - Separación clara de responsabilidades
    /// </remarks>
    private async Task SubmitPainPoint()
    {
        // Resetear mensajes
        errorMessage = string.Empty;
        showSuccessMessage = false;

        // Validación local
        if (string.IsNullOrWhiteSpace(painText))
        {
            errorMessage = "El dolor no puede estar vacío";
            return;
        }

        try
        {
            isSubmitting = true;

            // Crear el objeto de petición
            var request = new { Text = painText.Trim() };

            // Enviar al servidor
            var response = await Http.PostAsJsonAsync("api/painpoints", request);

            if (response.IsSuccessStatusCode)
            {
                // Éxito: Mostrar mensaje y limpiar formulario
                showSuccessMessage = true;
                painText = string.Empty;

                // Ocultar el mensaje de éxito después de 3 segundos
                _ = Task.Run(async () =>
                {
                    await Task.Delay(3000);
                    showSuccessMessage = false;
                    await InvokeAsync(StateHasChanged);
                });
            }
            else
            {
                // Error del servidor
                errorMessage = "Error al enviar. Intenta de nuevo.";
            }
        }
        catch (Exception ex)
        {
            // Error de conexión o inesperado
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
