<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!--
      CONFIGURACIÓN CORS PARA AZURE APP SERVICE (IIS)
      
      PROBLEMA RAÍZ: Azure App Service corre sobre IIS con el módulo CORS nativo.
      Cuando ese módulo está activo, intercepta las solicitudes OPTIONS (preflight)
      ANTES de que lleguen a ASP.NET Core y las puede rechazar con 400 Bad Request
      si el origen solicitante no está en su lista de orígenes permitidos.
      
      SOLUCIÓN DOBLE:
      1. Remover el módulo CORS nativo de IIS para que ASP.NET Core lo maneje.
      2. Agregar headers CORS a nivel de IIS como capa de respaldo absoluto.
    -->

    <!-- Paso 1: Deshabilitar el módulo CORS nativo de IIS -->
    <modules>
      <remove name="CorsModule" />
    </modules>

    <!-- Paso 2: Headers CORS a nivel IIS (respaldo si ASP.NET Core no los agrega) -->
    <httpProtocol>
      <customHeaders>
        <!-- 
          NOTA: estos headers se envían en TODAS las respuestas.
          ASP.NET Core puede sobreescribirlos o duplicarlos — eso está bien.
          La prioridad real la maneja el middleware de Program.cs.
          El valor "*" aquí es intencional como último recurso; el middleware
          de ASP.NET Core lo sobreescribe con el origen específico cuando corresponde.
        -->
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

    <!-- Paso 3: Regla de reescritura para responder 204 a OPTIONS directamente desde IIS -->
    <!-- Esto garantiza que el preflight nunca sea bloqueado por IIS -->
    <rewrite>
      <rules>
        <rule name="CORS Preflight OPTIONS" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_METHOD}" pattern="^OPTIONS$" />
          </conditions>
          <action type="CustomResponse" statusCode="204" statusReason="No Content" statusDescription="No Content" />
        </rule>
      </rules>
      <outboundRules>
        <rule name="Add CORS Headers" preCondition="OPTIONS" enabled="true">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern=".*" negate="false" />
          <action type="Rewrite" value="https://orange-moss-00032b10f.1.azurestaticapps.net" />
        </rule>
        <rule name="Add CORS Allow Headers" preCondition="OPTIONS" enabled="true">
          <match serverVariable="RESPONSE_Access_Control_Allow_Headers" pattern=".*" negate="false" />
          <action type="Rewrite" value="Content-Type, Authorization, X-Requested-With" />
        </rule>
        <rule name="Add CORS Allow Methods" preCondition="OPTIONS" enabled="true">
          <match serverVariable="RESPONSE_Access_Control_Allow_Methods" pattern=".*" negate="false" />
          <action type="Rewrite" value="GET, POST, PUT, DELETE, OPTIONS" />
        </rule>
        <rule name="Add CORS Allow Credentials" preCondition="OPTIONS" enabled="true">
          <match serverVariable="RESPONSE_Access_Control_Allow_Credentials" pattern=".*" negate="false" />
          <action type="Rewrite" value="true" />
        </rule>
        <preConditions>
          <preCondition name="OPTIONS">
            <add input="{REQUEST_METHOD}" pattern="OPTIONS" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <security>
      <requestFiltering>
        <!-- Permitir el método OPTIONS (a veces IIS lo bloquea por defecto) -->
        <verbs>
          <add verb="OPTIONS" allowed="true" />
          <add verb="GET" allowed="true" />
          <add verb="POST" allowed="true" />
          <add verb="PUT" allowed="true" />
          <add verb="DELETE" allowed="true" />
        </verbs>
      </requestFiltering>
    </security>

    <handlers>
      <!-- Asegurar que ASP.NET Core maneje todas las solicitudes -->
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>

    <aspNetCore processPath="dotnet"
                arguments=".\Poll-it.Server.dll"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
      </environmentVariables>
    </aspNetCore>

  </system.webServer>
</configuration>
