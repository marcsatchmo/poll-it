<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!--
      CONFIGURACIÓN CORS PARA AZURE APP SERVICE (IIS)

      PROBLEMA RAÍZ IDENTIFICADO: La regla CustomResponse para OPTIONS respondía
      con 204 directamente desde IIS, sin los headers CORS requeridos, porque las
      outbound rules NO se ejecutan sobre respuestas CustomResponse. El navegador
      recibía un 204 vacío y rechazaba el preflight.

      SOLUCIÓN DEFINITIVA:
      1. Remover el módulo CORS nativo de IIS (CorsModule) para que no interfiera.
      2. Permitir el verbo OPTIONS en el request filtering.
      3. NO interceptar OPTIONS con CustomResponse — dejar que pase a ASP.NET Core.
      4. ASP.NET Core (Program.cs) maneja OPTIONS y responde con los headers correctos.
    -->

    <!-- Paso 1: Deshabilitar el módulo CORS nativo de IIS -->
    <modules>
      <remove name="CorsModule" />
    </modules>

    <security>
      <requestFiltering>
        <!-- Permitir el método OPTIONS para que pase a ASP.NET Core -->
        <verbs>
          <add verb="OPTIONS" allowed="true" />
          <add verb="GET" allowed="true" />
          <add verb="POST" allowed="true" />
          <add verb="PUT" allowed="true" />
          <add verb="DELETE" allowed="true" />
        </verbs>
      </requestFiltering>
    </security>

    <handlers>
      <!-- ASP.NET Core maneja TODAS las solicitudes, incluido OPTIONS -->
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>

    <aspNetCore processPath="dotnet"
                arguments=".\Poll-it.Server.dll"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
      </environmentVariables>
    </aspNetCore>

  </system.webServer>
</configuration>
